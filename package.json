{
  "name": "@aranzatech/react-native-card-secure-view",
  "version": "0.1.0",
  "description": "Vista segura nativa iOS para datos sensibles de tarjetas — TurboModule con validación HMAC, protección anti-captura y timeout de sesión",
  "license": "MIT",
  "author": "AranzaTech",
  "keywords": [
    "react-native",
    "ios",
    "turbomodule",
    "new-architecture",
    "secure-view",
    "card",
    "pan",
    "cvv",
    "hmac",
    "aranzatech"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aranzatech/react-native-card-secure-view.git"
  },
  "bugs": {
    "url": "https://github.com/aranzatech/react-native-card-secure-view/issues"
  },
  "homepage": "https://github.com/aranzatech/react-native-card-secure-view#readme",
  "publishConfig": {
    "access": "public"
  },
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./lib/typescript/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "ios",
    "*.podspec",
    "README.md",
    "CHANGELOG.md",
    "!ios/CardSecureViewKit/.build"
  ],
  "scripts": {
    "build": "bob build",
    "ci": "npm run lint && npm run typecheck && npm run test:ci && npm run build",
    "lint": "eslint .",
    "prepare": "bob build",
    "start": "echo 'Librería sin app propia; usa la app de ejemplo del reto.'",
    "test": "jest",
    "test:ci": "jest --runInBand --watchman=false",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "devDependencies": {
    "@react-native/babel-preset": "0.86.0",
    "@react-native/eslint-config": "0.86.0",
    "@react-native/jest-preset": "^0.86.0",
    "@react-native/typescript-config": "0.86.0",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-builder-bob": "^0.40.13",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  },
  "codegenConfig": {
    "name": "NativeCardSecureViewSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.aranzatech.cardsecureview"
    },
    "ios": {
      "modulesProvider": {
        "NativeCardSecureView": "RCTNativeCardSecureView"
      }
    }
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
